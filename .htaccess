<IfModule mod_rewrite.c>
    RewriteEngine On

    # Set default controller/action if not provided
    RewriteRule ^$ index.php?controller=welcome&action=index [L,QSA]

    # If only controller is provided (e.g., /blog)
    RewriteRule ^([a-zA-Z0-9_-]+)/?$ index.php?controller=$1&action=index [L,QSA]

    # If controller and action are provided (e.g., /blog/view)
    RewriteRule ^([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/?$ index.php?controller=$1&action=$2 [L,QSA]
</IfModule>
